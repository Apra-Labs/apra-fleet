node_modules/
dist/
data/

# apra-fleet-se's package-local vendored schema snapshot (apra-fleet-bun):
# build artifact written by packages/apra-fleet-se/scripts/vendor-schemas.mjs,
# not a checked-in fixture (contrast with test/fixtures/vendor-apra-pm-schemas/).
packages/apra-fleet-se/vendor/schemas/
.fleet-task.md
*.js.map
*.tsbuildinfo
.env
*.pem
fleet.config.json
~/.claude-fleet/
materials/*
.claude/settings.local.json

# CLAUDE.md is already tracked (git add -f was used), so this entry only prevents
# new untracked CLAUDE.md files from being accidentally staged — it does not untrack the existing file.
CLAUDE.md

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/
.claude/settings.json

# E2E test fixtures (local only, never commit)
.e2e-fixtures/

# Provider agent context files are tracked project deliverables (git add -f was used).
# These entries prevent sprint-injected replacements from being accidentally staged.
GEMINI.md
AGENTS.md
COPILOT-INSTRUCTIONS.md

# local compose_permissions ledger artifact
/permissions.json

# Beads / Dolt files (added by bd init)
.beads/proxieddb/

# Local tool scaffolding, not project deliverables
.agents/
.codex/

# Auto-sprint scaffold logs left in repo root (not under sprint-logs/)
/auto-sprint-*.log
/auto-sprint-*.err.log

# Per-file integration-test progress state (scripts/run-integ-suites.mjs)
/integ-suite-status.json
/integ-suite-status.json.tmp
/integ-suite-heartbeat.json
/integ-suite-run.log
