{
  "name": "apra-fleet",
  "version": "0.1.4",
  "description": "MCP server for orchestrating multiple agentic AI instances like Claude, Gemini and others (called 'members') across machines via SSH",
  "author": "Apra Labs",
  "homepage": "https://github.com/Apra-Labs/apra-fleet",
  "repository": {
    "type": "git",
    "url": "https://github.com/Apra-Labs/apra-fleet.git"
  },
  "bugs": {
    "url": "https://github.com/Apra-Labs/apra-fleet/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:sea": "node scripts/build-sea.mjs",
    "build:sea-config": "node scripts/gen-sea-config.mjs",
    "build:sea-package": "node scripts/package-sea.mjs",
    "build:binary": "npm run build:sea && npm run build:sea-config && npm run build:sea-package",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsc && node dist/smoke-test.js",
    "integration": "tsc && npx tsx tests/integration.test.ts"
  },
  "keywords": [
    "ai-agent",
    "anthropic",
    "automation",
    "claude",
    "claude-code",
    "devtools",
    "fleet",
    "mcp",
    "model-context-protocol",
    "multi-agent",
    "orchestration",
    "remote-execution",
    "ssh"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@inquirer/password": "^5.0.11",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "smol-toml": "^1.6.1",
    "ssh2": "^1.17.0",
    "uuid": "^11.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ssh2": "^1.15.0",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.27.4",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
