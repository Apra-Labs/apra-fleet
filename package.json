{
  "name": "@apralabs/apra-fleet",
  "version": "0.4.0",
  "description": "MCP server for orchestrating multiple agentic AI instances (Claude, Gemini, Codex, Copilot, AGY) across machines via SSH",
  "author": "Apra Labs",
  "homepage": "https://github.com/Apra-Labs/apra-fleet",
  "repository": {
    "type": "git",
    "url": "https://github.com/Apra-Labs/apra-fleet.git"
  },
  "bugs": {
    "url": "https://github.com/Apra-Labs/apra-fleet/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/apra-fleet-client",
    "packages/apra-fleet-workflow",
    "packages/apra-fleet-se",
    "packages/fleet-api-contract"
  ],
  "main": "dist/index.js",
  "bin": {
    "apra-fleet": "dist/index.js",
    "auto-sprint": "dist/auto-sprint.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/",
    "hooks/",
    "scripts/fleet-statusline.sh",
    "scripts/agy-transcript-reader.js",
    "skills/",
    "version.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build:contract && tsc",
    "build:contract": "npm run build --workspace=@apralabs/fleet-api-contract",
    "gen:openapi": "npm run gen:openapi --workspace=@apralabs/fleet-api-contract",
    "dist-pm": "node scripts/dist-pm.mjs",
    "build:sea": "node scripts/build-sea.mjs",
    "build:sea-config": "node scripts/gen-sea-config.mjs",
    "build:sea-package": "node scripts/package-sea.mjs",
    "build:binary": "npm run build && npm run build:sea && npm run build:sea-config && npm run build:sea-package",
    "build:se": "node scripts/bundle-se.mjs",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "pretest": "npm run build:contract",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsc && node dist/smoke-test.js",
    "integration": "tsc && npx tsx tests/integration.test.ts",
    "prepare": "node scripts/install-hooks.mjs",
    "prepublishOnly": "npm run dist-pm && npm run vendor-schemas --workspace=@apralabs/apra-fleet-se && npm run build && npm run build:se"
  },
  "keywords": [
    "ai-agent",
    "anthropic",
    "automation",
    "claude",
    "claude-code",
    "devtools",
    "fleet",
    "mcp",
    "model-context-protocol",
    "multi-agent",
    "orchestration",
    "remote-execution",
    "ssh"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@inquirer/password": "^5.0.11",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "ajv": "^8.12.0",
    "pg": "^8.22.0",
    "smol-toml": "^1.6.1",
    "ssh2": "^1.17.0",
    "uuid": "^14.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@apralabs/fleet-api-contract": "^0.1.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/ssh2": "^1.15.0",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.27.4",
    "pg-mem": "^3.0.14",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
