{
  "name": "claude-code-fleet-mcp",
  "version": "1.1.0",
  "description": "MCP server for managing a fleet of remote Claude Code agents via SSH",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsc && node dist/smoke-test.js",
    "integration": "tsc && npx tsx tests/integration.test.ts"
  },
  "keywords": [
    "mcp",
    "claude",
    "fleet",
    "ssh",
    "remote"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "ssh2": "^1.17.0",
    "uuid": "^11.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ssh2": "^1.15.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
